generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  NEW
  CONTACTED
  CONFIRMED
  CLOSED
}

enum MessageStatus {
  NEW
  READ
  REPLIED
}

model BookingRequest {
  id            String        @id @default(cuid())
  name          String
  phone         String
  program       String
  preferredDate String?
  preferredTime String?
  notes         String?
  status        BookingStatus @default(NEW)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  message   String
  status    MessageStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}
