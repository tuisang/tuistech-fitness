generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  NEW
  CONTACTED
  CONFIRMED
  CLOSED
}

enum MessageStatus {
  NEW
  READ
  REPLIED
}

enum EbookOrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

model EbookOrder {
  id                String           @id @default(cuid())
  ebookSlug         String
  ebookTitle        String
  phone             String
  email             String
  amountKes         Int
  checkoutRequestId String?          @unique
  merchantRequestId String?
  mpesaReceiptNumber String?
  status            EbookOrderStatus @default(PENDING)
  deliveredAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([checkoutRequestId])
}

model BookingRequest {
  id            String        @id @default(cuid())
  name          String
  phone         String
  program       String
  preferredDate String?
  preferredTime String?
  notes         String?
  status        BookingStatus @default(NEW)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  message   String
  status    MessageStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}